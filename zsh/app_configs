# Note: some tools are also managed by antigen plugins (pyenv, nvm, rbenv, etc.)
#       this file handles their shell-level initialization.

# ---------------------------------------------------------------------------
# homebrew
# ---------------------------------------------------------------------------
export HOMEBREW_NO_AUTO_UPDATE=1

# ---------------------------------------------------------------------------
# pyenv
# ref: https://github.com/pyenv/pyenv
# ---------------------------------------------------------------------------
if command -v pyenv 1>/dev/null 2>&1; then
  echo "[pyenv] initializing"
  export PYENV_ROOT="$HOME/.pyenv"
  export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init --path)"
fi

# ---------------------------------------------------------------------------
# sdkman
# ref: https://sdkman.io
# ---------------------------------------------------------------------------
if [ -d ~/.sdkman ]; then
  echo "[sdkman] initializing"
  source "$HOME/.sdkman/bin/sdkman-init.sh"
fi

# ---------------------------------------------------------------------------
# nvm — loaded from homebrew
# ref: https://github.com/nvm-sh/nvm
# ---------------------------------------------------------------------------
export NVM_DIR="$HOME/.nvm"
if [ -s "$HOMEBREW_PREFIX/opt/nvm/nvm.sh" ]; then
  echo "[nvm] initializing"
  source "$HOMEBREW_PREFIX/opt/nvm/nvm.sh"
  [ -s "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \
    source "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"
fi

# ---------------------------------------------------------------------------
# direnv
# ref: https://direnv.net
# ---------------------------------------------------------------------------
eval "$(direnv hook zsh)"

# ---------------------------------------------------------------------------
# paste fix — prevents slow paste caused by url-quote-magic
# ---------------------------------------------------------------------------
pasteinit() {
  OLD_SELF_INSERT=${${(s.:.)widgets[self-insert]}[2,3]}
  zle -N self-insert url-quote-magic
}
pastefinish() {
  zle -N self-insert $OLD_SELF_INSERT
}
zstyle :bracketed-paste-magic paste-init pasteinit
zstyle :bracketed-paste-magic paste-finish pastefinish

# ---------------------------------------------------------------------------
# spaceship prompt
# ref: https://spaceship-prompt.sh
# ---------------------------------------------------------------------------
SPACESHIP_PROMPT_ORDER=(
  time           # timestamp
  user           # username
  dir            # current directory
  host           # hostname
  git            # git branch + status

  node
  ruby
  python
  venv

  azure
  terraform

  async          # async jobs indicator
  line_sep       # line break
  jobs           # background jobs indicator
  exit_code      # exit code of last command
  sudo           # sudo indicator
  char           # prompt character
)

SPACESHIP_GIT_STATUS_SHOW=false
SPACESHIP_PROMPT_ASYNC=true
SPACESHIP_VENV_ASYNC=true
SPACESHIP_VENV_PREFIX="${SPACESHIP_PROMPT_DEFAULT_PREFIX}venv:("
SPACESHIP_VENV_SUFFIX=") "

# vi mode config lives in pre_antigen — must load before antigen
